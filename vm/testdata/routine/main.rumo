fmt := import("fmt")
time := import("time")

writeRoutine := func(num) {
    return func() {
        defer func() {
            fmt.println("Routine " + num + " exiting")
        }()
        fmt.println("Starting writeRoutine: " + num)
        for i := 0; i < 12; i++ {
            fmt.println("Hello from writeRoutine: "+ num + " i: " + i)
            time.sleep(250*time.millisecond)
        }
        return "routine " + num + " done"
    }
}

r1 := start writeRoutine(1)()
r2 := start writeRoutine(2)()
r3 := start writeRoutine(3)()
time.sleep(1 * time.second)
fmt.println("Cancelling routine 1")
r1.stop()


time.sleep(2 * time.second)
fmt.println("Cancelling routine 2")
r2.stop()

fmt.println("Waiting for routine 3 to finish")
r3.wait()
fmt.println("All routines finished")

ret1 := r1.result()
ret2 := r2.result()
ret3 := r3.result()
fmt.println("Routine 1 result: " + ret1)
fmt.println("Routine 2 result: " + ret2)
fmt.println("Routine 3 result: " + ret3)
