// Demonstrates linking against libm at runtime and calling into C from
// a rumo script.  The `native` statement declares which symbols to bind
// and how they look from C land - rumo then converts values for every
// call automatically.

fmt := import("fmt")

native libm = "libm.so.6" {
    sqrt: func(float) float
    pow:  func(float, float) float
    fabs: func(float) float
}

fmt.println("sqrt(2)      =", libm.sqrt(2.0))
fmt.println("pow(2, 10)   =", libm.pow(2.0, 10.0))
fmt.println("fabs(-3.14)  =", libm.fabs(-3.14))

// Short-form declarations drop the `: func` prefix.
native libc = "libc.so.6" {
    strlen(string) int
    abs(int) int
}

fmt.println("strlen(hi!)  =", libc.strlen("hi!"))
fmt.println("abs(-42)     =", libc.abs(-42))
